{
  "name": "keystatic-demo",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --cache --list-different --write .",
    "docs:prepare": "sh scripts/prepare-sphinx-content.sh",
    "docs:build": "npm run docs:prepare && sphinx-build -b rinoh docs docs/_build/pdf && sphinx-build -b epub docs docs/_build/epub && sphinx-build -b html docs docs/_build/html && sh scripts/build-per-page-docs.sh"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/react": "^5.0.3",
    "@astrojs/starlight": "^0.38.3",
    "@calponia/common-ui-primereact-theme": "^1.4.2",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.50",
    "@types/archiver": "^7.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "archiver": "^7.0.1",
    "astro": "^6.0.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "sass": "^1.99.0"
  }
}
