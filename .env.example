# GitHub App credentials (create at https://github.com/settings/apps)
# Callback URL: http://127.0.0.1:4321/api/keystatic/github/oauth/callback
# Requires: Contents (read & write) permission, "Expire user authorization tokens" enabled
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Secret for encrypting refresh tokens (minimum 32 characters)
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
KEYSTATIC_SECRET=